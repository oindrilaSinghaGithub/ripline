# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONNECTION
# ─────────────────────────────────────────────────────────────────────────────

# Aurora PostgreSQL connection string
DATABASE_URL="YOUR_DATABASE_URL"

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Aurora IAM Authentication
# ─────────────────────────────────────────────────────────────────────────────

# AURORA_IAM_AUTH=true
# AWS_AURORA_HOST=YOUR_AURORA_HOST
# AWS_AURORA_PORT=5432
# AWS_AURORA_USER=YOUR_DATABASE_USER
# AWS_AURORA_DB=YOUR_DATABASE_NAME
# AWS_REGION=YOUR_AWS_REGION
# AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# AWS_SESSION_TOKEN=YOUR_AWS_SESSION_TOKEN

# ─────────────────────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# ─────────────────────────────────────────────────────────────────────────────

AUTH_SECRET="GENERATE_A_RANDOM_SECRET"
AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────────
# OAuth Providers
# ─────────────────────────────────────────────────────────────────────────────

AUTH_GITHUB_ID="YOUR_GITHUB_CLIENT_ID"
AUTH_GITHUB_SECRET="YOUR_GITHUB_CLIENT_SECRET"

AUTH_GOOGLE_ID="YOUR_GOOGLE_CLIENT_ID"
AUTH_GOOGLE_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Ripline"

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (Optional)
# Leave blank to use the built-in heuristic extractor.
# ─────────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY="YOUR_OPENAI_API_KEY"

# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_MAX_TOKENS="2048"
# OPENAI_API_TYPE="azure"

# ─────────────────────────────────────────────────────────────────────────────
# OCR (Optional)
# Leave blank to use mock OCR.
# ─────────────────────────────────────────────────────────────────────────────

# OCR_PROVIDER="textract"

# AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
# AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# AWS_REGION="YOUR_AWS_REGION"